        "spotify": "’å╝",
        "default": "­¤Ä£"
      },
      "escape": true,
      "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null"
    },
    

    /* ---------- System Modules ---------- */
    "clock": {
      "format": " {:%I:%M} ",
      "tooltip-format": " {:%A, %B %d, %Y} ",
      "format-alt": " {:%Y-%m-%d} "
    },

    

    "battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": " {icon}{capacity}% ",
      "format-full": " ’ēĆ {capacity}% ",
      "format-charging": " ’ā¦ {capacity}% ",
      "format-plugged": " ŅĢ£ {capacity}% ",
      "format-alt": " {time} {icon} ",
      "format-icons": ["’ēä ", "’ēā ", "’ēé ", "’ēü ", "’ēĆ "]
    },

    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "format-icons": {
        "default": "’ā¦",
        "performance": "’ā¦",
        "balanced": "’ēÄ",
        "power-saver": "’ü¼"
      }
    },

    "cpu": {
      "format": "CPU {usage}% ’ŗø",
      "tooltip": false
    },
    "temperature": {
      "critical-threshold": 80,
      "format": "{temperatureC}┬░C {icon}",
      "format-icons": ["’Ø½", "’ŗē", "’Ø®"]
    },

    "backlight": {
      "format": "{percent}% {icon}",
      "format-icons": ["ŅÄŹ", "ŅÅō", "ŅÅæ", "ŅÅÅ", "ŅÅÄ", "ŅÅŹ", "ŅÅŖ", "ŅÅł", "ŅÄø"]
    },

    "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
        "activated": "’ü«",
        "deactivated": "’ü░"
      }
    },

    "keyboard-state": {
      "numlock": true,
      "capslock": true,
      "format": "{name} {icon}",
      "format-icons": {
        "locked": "’ĆŻ",
        "unlocked": "’Åü"
      }
    },

    "tray": {
      "spacing": 5,
         "icon-size": 18,
    "show-passive-icons": true
    },

    "memory": { "format": "’ŗø {}%" },
    "pulseaudio": {
      "format": "’Ć© {volume}% ",
      "format-muted": "’Ü®",
      "format-source": "’ĆÆ {volume}% ’ä░",
      "format-source-muted": "’ä▒",
      "format-icons": {
        "default": ["’Ć”", "’Ć¦", "’Ć©"]
      },
      "on-click": "pavucontrol"
    },
    "network": {
      "format-wifi": "^^",
      "format-ethernet": "{ipaddr}/{cidr} ¾░ŖŚ ",
      "tooltip-format": "{ifname} via {gwaddr} ¾░ŖŚ ",
      "format-linked": "{ifname} (No IP) ¾░ŖŚ ",
      "format-disconnected": "X_X ŌÜĀ",
      "on-click": "exec kitty -e nmtui"
    }
  }
    
]

