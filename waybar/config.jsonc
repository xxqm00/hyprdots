    },

    "custom/spotify": {
      "format": " {} ",
      "return-type": "json",
      "interval": 1,
      "exec": "playerctl -p spotify metadata --format '{\"text\": \"{{artist}} - {{title}}\", \"alt\": \"{{status}}\", \"tooltip\": \"{{title}} - {{artist}}\"}'",
      "on-click": "playerctl -p spotify play-pause"
    },

    "custom/media": {
      "format": "{icon} {text}",
