{
    "logo": {
    "type": "builtin",        // Logo type: auto, builtin, small, file, etc.
    "source": "arch",      // Built-in logo name or file path
    "width": 10,           // Width in characters
    "height": 5          // Height in characters
    	},
"display": {
        "separator": "  ",
        "color": "white"
    },
    "modules": [
         "break",
           {
            "type": "custom",
            "key": "                         Welcome back, kie"
        },
        {
            "type": "custom",
            "key": "            ╭─────────────────────────────────────────╮"
        },
        // {
        //     "type": "custom",
        //     "key": "│                                         │"
        // },
         {
            "type": "os",
            "key": "            │  OS           ",
            "format": "{pretty-name>22}  │"
        },
        {
            "type": "command",
            "key": "            │  Kernel       ",
            "text": "uname -r | cut -d '-' -f1",
            "format": "{>22}  │"
        },
        {
            "type": "command",
            "key": "            │  Uptime       ",
            "text": "uptime -p | sed -E 's/up //; s/ days?/d/g; s/ hours?/h/g; s/ minutes?/m/g'",
            "format": "{>22}  │"
        },
        {
            "type": "shell",
            "key": "            │  Shell        ",
            "format": "{pretty-name>22}  │"
        },
        {
            "type": "command",
            "key": "            │  WM           ",
            "text": "echo $XDG_CURRENT_DESKTOP",
            "format": "{>22}  │"
        },
        {
	        "key": "            │  OS Age                      ",
            "type": "disk",
	        "folders": "/",
	        "format": "{days} days   │"
	    },
        {
            "type": "command",
            "key": "            │  Ram          ",
            "text": "free -m | awk 'NR==2{printf \"%.2f / %.2f GiB\",$3/1024,$2/1024}'",
            "format": "{>22}  │"
        },
        {
            "type": "command",
            "key": "            │  CPU          ",
            "text": "lscpu | grep 'Model name' | sed -E 's/.*(i[0-9]-[0-9A-Za-z]+).*/\\1/'",
            "format": "{>22}  │"
        },
        {
            "type": "command",
            "key": "            │  Disk         ",
            "format": "{>22  │"
        },

        {
            "type": "packages",
            "key": "            │  Packages     ",
            "format": "{all>22}  │"
        },
        // {
        //     "type": "custom",
        //     "key": "│                                         │"
        // },
        {
            "type": "custom",
            "key": "            ╰─────────────────────────────────────────╯"
        },
        {
            "type": "disk",
            "key": "              ",
            "format": "{size-used} / {size-total} ({size-percentage}) {filesystem}"
        }
    ]
}