/* .control-center > box > scrolledwindow > viewport > box > .widget-container {
    background-color: #e7e7e7;
    border-radius: 10px;
    margin: 4px 4px;
} */
/* Unified widget area background */
.control-center > box > scrolledwindow > viewport > box {
    background-color: rgba(200, 200, 200, 1);
    border-radius: 10px;
    margin: 4px;
    box-shadow: 0 0 6px 0 rgba(0, 0, 0, 0.15);
}